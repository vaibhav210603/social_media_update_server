  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/nodemailer": "^6.4.15",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "@vercel/node": "^3.2.0"
  }
}
